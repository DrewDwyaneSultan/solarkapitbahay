# =============================================================================
# SolarKapitBahay — Environment Variables
# =============================================================================
#
# LOCAL DEV:
#   1. Copy this file:  copy .env.example .env
#   2. Fill in values below
#   3. For local full stack, only DATABASE_URL is optional (uses SQLite if empty)
#
# VERCEL DEPLOY:
#   Project → Settings → Environment Variables → Add each key below
#   Framework Preset must be "Services" (see docs/DEPLOY_VERCEL.md)
#
#   Required on Vercel:  DATABASE_URL, SUPABASE_JWT_SECRET
#   Required on Vercel (frontend): VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY
#   Leave blank on Vercel: VITE_API_URL (same-domain /api)
#   Auth setup guide: docs/AUTH_SETUP.md
#   Live MQTT on Vercel: docs/MQTT_VERCEL.md
#
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED FOR VERCEL (Supabase — persistent database)
# -----------------------------------------------------------------------------
# Supabase → your project → Connect (top button)
#
# VERCEL / SERVERLESS: use "Session pooler" or "Transaction pooler" — NOT "Direct connection"
# Direct (db.xxx.supabase.co:5432) uses IPv6 and often fails on Vercel with:
#   "Cannot assign requested address"
#
# Session pooler (port 5432) — example:
# DATABASE_URL=postgresql://postgres.grqkeswrzxvxesofpbjc:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
#
# Transaction pooler (port 6543) — also works for serverless:
# DATABASE_URL=postgresql://postgres.grqkeswrzxvxesofpbjc:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
#
# Replace YOUR_PASSWORD, region (ap-southeast-1 etc.), and project ref with yours from Supabase Connect.

DATABASE_URL=postgresql://postgres.grqkeswrzxvxesofpbjc:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Optional alias (same as DATABASE_URL — use one or the other)
# SUPABASE_DB_URL=


# -----------------------------------------------------------------------------
# FRONTEND (Vite — only vars prefixed VITE_ are exposed to the browser)
# -----------------------------------------------------------------------------

# Vercel Services (frontend + backend on one URL): LEAVE EMPTY
# API calls go to /api on the same domain automatically.
VITE_API_URL=

# Only set this if frontend and API are on DIFFERENT hosts (e.g. separate Render API):
# VITE_API_URL=https://your-api-host.example.com

# Supabase Auth (browser — safe to expose anon key)
# Supabase → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend JWT validation (server only — never expose to frontend)
# Supabase → Project Settings → API → JWT Settings → Legacy JWT Secret (HS256)
SUPABASE_JWT_SECRET=your-jwt-secret

# Same as VITE_SUPABASE_URL — backend uses this for ES256 JWT verification (JWKS)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co


# -----------------------------------------------------------------------------
# LOCAL DEV ONLY (do not add to Vercel unless you know you need them)
# -----------------------------------------------------------------------------

# Override SQLite file path when DATABASE_URL is not set
# DATABASE_PATH=backend/solarkapitbahay.db

# -----------------------------------------------------------------------------
# LIVE MQTT (required on Vercel for Energy Transfer page; optional locally)
# -----------------------------------------------------------------------------
# Use a public broker both ESP32 and Vercel can reach (HiveMQ Cloud free tier, etc.).
# Local lab without these vars defaults to 127.0.0.1:1883 (Mosquitto on laptop).
#
# MQTT_BROKER_HOST=your-cluster.s1.eu.hivemq.cloud
# MQTT_BROKER_PORT=8883
# MQTT_BROKER_USERNAME=your-hivemq-username
# MQTT_BROKER_PASSWORD=your-hivemq-password
# MQTT_USE_TLS=true
# MQTT_SYNC_TIMEOUT=2.0
#
# Optional: secret for POST /api/mqtt/ingest webhooks from the broker
# MQTT_INGEST_SECRET=choose-a-long-random-string

# Backend port when running: npm run dev:backend  (default 8000)
# PORT=8000


# -----------------------------------------------------------------------------
# AUTO-SET BY VERCEL — do not add manually
# -----------------------------------------------------------------------------
# VERCEL=1
# VERCEL_URL=your-app.vercel.app
