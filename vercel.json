{
  "experimentalServices": {
    "frontend": {
      "framework": "vite",
      "routePrefix": "/"
    },
    "backend": {
      "framework": "fastapi",
      "entrypoint": "backend/main.py",
      "routePrefix": "/api",
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": ["backend/data/**", "data/**", "supabase/**"]
    }
  }
}
